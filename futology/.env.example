# =============================================================================
# FUTOLOGY - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values
# For demo mode, only DEMO_MODE=true is required
# =============================================================================

# === Supabase (Database + Auth + Realtime) ===
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === API-Football (RapidAPI) ===
# Sign up: https://rapidapi.com/api-sports/api/api-football
RAPIDAPI_KEY=your-rapidapi-key
RAPIDAPI_HOST=api-football-v1.p.rapidapi.com

# === football-data.org (free tier available) ===
# Sign up: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your-football-data-key

# === NewsAPI ===
# Sign up: https://newsapi.org/register
NEWS_API_KEY=your-newsapi-key

# === Resend (email notifications) ===
# Sign up: https://resend.com/signup
RESEND_API_KEY=re_your-resend-key
RESEND_FROM_EMAIL=noreply@futology.com

# === ML Service (FastAPI) ===
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_TOKEN=your-ml-service-token

# === Reddit (sentiment analysis) ===
# Create app: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=Futology/1.0

# === Twitter API (optional) ===
# Apply: https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# === Upstash Redis (caching) ===
# Create DB: https://upstash.com/
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# === Feature Flags ===
DEMO_MODE=true
ENABLE_TWITTER_SENTIMENT=false

# === App Configuration ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Futology
